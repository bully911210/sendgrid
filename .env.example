# SendGrid API Key (server-side only on Vercel)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# GitHub storage for SigMail settings (backs /api/settings)
# Create a fine-grained Personal Access Token scoped to this repo with
# "Contents: Read and write" permission, then add it in Vercel → Settings →
# Environment Variables. Optional vars default to the values shown.
GITHUB_TOKEN=your_github_pat_here
GITHUB_OWNER=bully911210
GITHUB_REPO=sendgrid
# GITHUB_SETTINGS_PATH=data/settings.json
# GITHUB_BRANCH=main
